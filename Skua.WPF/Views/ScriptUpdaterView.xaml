<UserControl
    x:Class="Skua.WPF.Views.ScriptUpdaterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:managerVMs="clr-namespace:Skua.Core.ViewModels.Manager;assembly=Skua.Core"
    d:DataContext="{d:DesignInstance managerVMs:ScriptUpdaterViewModel}"
    mc:Ignorable="d"
    d:DesignHeight="400" d:DesignWidth="600">
    <Grid Margin="16" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <materialDesign:PackIcon
                Kind="CodeTags"
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                Foreground="{DynamicResource PrimaryHueMidBrush}"
                Margin="0,0,0,24" />

            <TextBlock
                Text="Skua Scripts Updater"
                Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                HorizontalAlignment="Center"
                Margin="0,0,0,8" />

            <TextBlock
                Text="{Binding Status}"
                Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                HorizontalAlignment="Center"
                Margin="0,0,0,24" />

            <ProgressBar
                Value="0"
                IsIndeterminate="{Binding IsBusy}"
                Minimum="0" Maximum="100"
                Height="10"
                Margin="0,0,0,24"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
            
            <TextBlock
                Text="{Binding ProgressStatus}"
                Style="{StaticResource MaterialDesignBody2TextBlock}"
                HorizontalAlignment="Center"
                Margin="0,0,0,24"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button
                    Command="{Binding UpdateScriptsCommand}"
                    Content="Update Scripts"
                    Margin="0,0,16,0"
                    Width="160" />

                <Button
                    Command="{Binding ResetScriptsCommand}"
                    Content="Reset Scripts"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Foreground="{DynamicResource SecondaryHueMidBrush}"
                    BorderBrush="{DynamicResource SecondaryHueMidBrush}"
                    Width="160" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
