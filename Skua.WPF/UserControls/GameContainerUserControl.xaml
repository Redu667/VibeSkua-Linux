<UserControl
    x:Class="Skua.WPF.UserControls.GameContainerUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Skua.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid x:Name="RootGrid" SizeChanged="RootGrid_SizeChanged">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF121212" Offset="0.0" />
                <GradientStop Color="#FF1C0028" Offset="0.5" />
                <GradientStop Color="#FF2D003E" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Sidebar Dashboard -->
        <Viewbox x:Name="DashboardContainer" HorizontalAlignment="Right" VerticalAlignment="Center" Stretch="Uniform" StretchDirection="DownOnly" Panel.ZIndex="0">
            <Border Width="200" Margin="0,0,10,0" Padding="15" Background="#80000000" CornerRadius="8">
                <StackPanel x:Name="HudPanel">
                <TextBlock Text="BOT DASHBOARD" Foreground="#FFD080FF" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                <TextBlock Text="Kills:" Foreground="Gray" FontSize="12"/>
                <TextBlock Text="{Binding ScriptStats.Kills}" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock Text="Drops Picked:" Foreground="Gray" FontSize="12"/>
                <TextBlock Text="{Binding ScriptStats.Drops}" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock Text="Quests Completed:" Foreground="Gray" FontSize="12"/>
                <TextBlock Text="{Binding ScriptStats.QuestsCompleted}" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock Text="Deaths:" Foreground="Gray" FontSize="12"/>
                <TextBlock Text="{Binding ScriptStats.Deaths}" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock Text="Relogins:" Foreground="Gray" FontSize="12"/>
                <TextBlock Text="{Binding ScriptStats.Relogins}" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
        </Viewbox>

        <ProgressBar
            x:Name="LoadingBar"
            Width="150"
            Height="150"
            IsIndeterminate="True"
            Style="{StaticResource MaterialDesignCircularProgressBar}" />
        <WindowsFormsHost
            x:Name="gameContainer"
            Margin="1,0,1,1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="1"
            Visibility="Hidden" />
        <Grid x:Name="HeadlessOverlay" Background="Black" Panel.ZIndex="2" Visibility="Collapsed">
            <TextBlock Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold">Headless Mode Active</TextBlock>
            <TextBlock Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,50,0,0" FontSize="14">Rendering suspended to reduce CPU usage.</TextBlock>
        </Grid>
    </Grid>
</UserControl>