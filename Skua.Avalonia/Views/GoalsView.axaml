<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels.Manager;assembly=Skua.Core"
             xmlns:models="clr-namespace:Skua.Core.Models.GitHub;assembly=Skua.Core.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Skua.Avalonia.Views.GoalsView"
             x:DataType="vm:GoalsViewModel">

    <DockPanel Margin="24" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <Button Content="Support on Ko-fi" Command="{Binding OpenKofiLink}" />
            <Button Content="Support on PayPal" Command="{Binding OpenPaypalLink}" />
        </StackPanel>

        <!-- Shown when there are no goals loaded (e.g. offline). -->
        <TextBlock DockPanel.Dock="Top" Text="{Binding Status}"
                   IsVisible="{Binding !Goals.Count}"
                   Foreground="#A6ADC8" Margin="0,0,0,8" />

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Goals}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:GoalObject">
                        <Border Padding="12" Margin="0,0,0,8" CornerRadius="6" Background="#181825">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" />
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                           Foreground="#A6ADC8" />
                                <ProgressBar Minimum="0" Maximum="{Binding GoalValue}"
                                             Value="{Binding CurrentValue}" Height="6" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

</UserControl>
