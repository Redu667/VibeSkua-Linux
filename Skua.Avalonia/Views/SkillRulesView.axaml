<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="600"
             x:Class="Skua.Avalonia.Views.SkillRulesView"
             x:DataType="vm:SkillRulesViewModel">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="14">

            <TextBlock Text="Skill Use Rules" FontSize="16" FontWeight="Bold" />

            <!-- Health -->
            <Border Padding="12" CornerRadius="6" Background="#181825">
                <StackPanel Spacing="6">
                    <TextBlock Text="Health" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ToggleSwitch IsChecked="{Binding HealthGreaterThanBool}"
                                      OnContent="≥" OffContent="≤" />
                        <TextBox Width="90" Text="{Binding HealthUseValue}" Watermark="value" />
                        <CheckBox Content="percentage" IsChecked="{Binding HealthIsPercentage}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Mana -->
            <Border Padding="12" CornerRadius="6" Background="#181825">
                <StackPanel Spacing="6">
                    <TextBlock Text="Mana" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ToggleSwitch IsChecked="{Binding ManaGreaterThanBool}"
                                      OnContent="≥" OffContent="≤" />
                        <TextBox Width="90" Text="{Binding ManaUseValue}" Watermark="value" />
                        <CheckBox Content="percentage" IsChecked="{Binding ManaIsPercentage}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Party member health -->
            <Border Padding="12" CornerRadius="6" Background="#181825">
                <StackPanel Spacing="6">
                    <TextBlock Text="Party member health" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ToggleSwitch IsChecked="{Binding PartyMemberHealthGreaterThanBool}"
                                      OnContent="≥" OffContent="≤" />
                        <TextBox Width="90" Text="{Binding PartyMemberHealthUseValue}" Watermark="value" />
                        <CheckBox Content="percentage" IsChecked="{Binding PartyMemberHealthIsPercentage}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Wait / skip -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Wait (ms)" VerticalAlignment="Center" />
                <TextBox Width="90" Text="{Binding WaitUseValue}" />
                <CheckBox Content="Skip use" IsChecked="{Binding SkipUseBool}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Multi-aura checks: each item rendered via the ViewLocator as an AuraCheckView. -->
            <Border Padding="12" CornerRadius="6" Background="#181825">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Aura checks" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <CheckBox Content="enabled" IsChecked="{Binding MultiAuraBool}" />
                        <Button Content="Add" Command="{Binding AddAuraCheckCommand}" />
                        <Button Content="Reset all rules" Command="{Binding ResetUseRulesCommand}" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding MultiAuraChecks}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
