<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="300"
             x:Class="Skua.Avalonia.Views.ColorSchemeEditorView"
             x:DataType="vm:ColorSchemeEditorViewModel">

    <StackPanel Margin="24" Spacing="12" HorizontalAlignment="Left" MinWidth="340">
        <TextBlock Text="Accent color" FontSize="16" FontWeight="Bold" />
        <TextBlock Text="Recolors selections, toggles, focus and highlights across the app. (Fluent uses a single accent — there's no separate primary/secondary like the Windows build.)"
                   Opacity="0.7" TextWrapping="Wrap" />

        <!-- Preset swatches. Each button applies its color via the existing
             ChangeCustomHueCommand (RelayCommand<object> -> ThemeService.ChangeCustomColor). -->
        <WrapPanel>
            <Button Background="#FF607D8B" Width="34" Height="34" Margin="0,0,6,6"
                    Command="{Binding ChangeCustomHueCommand}" CommandParameter="#FF607D8B" ToolTip.Tip="Blue Grey" />
            <Button Background="#FF3F51B5" Width="34" Height="34" Margin="0,0,6,6"
                    Command="{Binding ChangeCustomHueCommand}" CommandParameter="#FF3F51B5" ToolTip.Tip="Indigo" />
            <Button Background="#FF2196F3" Width="34" Height="34" Margin="0,0,6,6"
                    Command="{Binding ChangeCustomHueCommand}" CommandParameter="#FF2196F3" ToolTip.Tip="Blue" />
            <Button Background="#FF009688" Width="34" Height="34" Margin="0,0,6,6"
                    Command="{Binding ChangeCustomHueCommand}" CommandParameter="#FF009688" ToolTip.Tip="Teal" />
            <Button Background="#FF4CAF50" Width="34" Height="34" Margin="0,0,6,6"
                    Command="{Binding ChangeCustomHueCommand}" CommandParameter="#FF4CAF50" ToolTip.Tip="Green" />
            <Button Background="#FFFF9800" Width="34" Height="34" Margin="0,0,6,6"
                    Command="{Binding ChangeCustomHueCommand}" CommandParameter="#FFFF9800" ToolTip.Tip="Orange" />
            <Button Background="#FFF44336" Width="34" Height="34" Margin="0,0,6,6"
                    Command="{Binding ChangeCustomHueCommand}" CommandParameter="#FFF44336" ToolTip.Tip="Red" />
            <Button Background="#FF9C27B0" Width="34" Height="34" Margin="0,0,6,6"
                    Command="{Binding ChangeCustomHueCommand}" CommandParameter="#FF9C27B0" ToolTip.Tip="Purple" />
            <Button Background="#FFCBA6F7" Width="34" Height="34" Margin="0,0,6,6"
                    Command="{Binding ChangeCustomHueCommand}" CommandParameter="#FFCBA6F7" ToolTip.Tip="Mauve" />
        </WrapPanel>

        <TextBlock Text="Custom (hex, e.g. #FF607D8B):" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="HueBox" Width="160" Watermark="#FF607D8B" />
            <Button Content="Apply"
                    Command="{Binding ChangeCustomHueCommand}"
                    CommandParameter="{Binding #HueBox.Text}" />
        </StackPanel>
    </StackPanel>

</UserControl>
