<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="380" d:DesignHeight="260"
             x:Class="Skua.Avalonia.Views.ColorSchemeEditorView"
             x:DataType="vm:ColorSchemeEditorViewModel">

    <StackPanel Margin="24" Spacing="12" HorizontalAlignment="Left">
        <TextBlock Text="Color scheme" FontSize="16" FontWeight="Bold" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Primary" Command="{Binding ChangeToPrimaryCommand}" />
            <Button Content="Secondary" Command="{Binding ChangeToSecondaryCommand}" />
            <Button Content="Primary FG" Command="{Binding ChangeToPrimaryForegroundCommand}" />
            <Button Content="Secondary FG" Command="{Binding ChangeToSecondaryForegroundCommand}" />
        </StackPanel>
        <Button Content="Change custom hue" Command="{Binding ChangeCustomHueCommand}" HorizontalAlignment="Left" />
    </StackPanel>

</UserControl>
