<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="400"
             x:Class="Skua.Avalonia.Views.FastTravelView"
             x:DataType="vm:FastTravelViewModel">

    <DockPanel Margin="24" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <TextBlock Text="Fast Travel" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Content="Add" Command="{Binding AddFastTravelCommand}" />
            <Button Content="Save" Command="{Binding SaveFastTravelsCommand}" />
            <Button Content="Clear" Command="{Binding ClearFastTravelsCommand}" />
        </StackPanel>

        <ListBox ItemsSource="{Binding FastTravelItems}" SelectedIndex="{Binding SelectedIndex}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:FastTravelItemViewModel">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding DescriptionName}" FontWeight="SemiBold" />
                            <TextBlock Foreground="#A6ADC8">
                                <Run Text="{Binding MapName}" />
                                <Run Text=" · " />
                                <Run Text="{Binding Cell}" />
                                <Run Text=" · " />
                                <Run Text="{Binding Pad}" />
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Travel"
                                Command="{Binding TravelCommand}" CommandParameter="{Binding}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>

</UserControl>
