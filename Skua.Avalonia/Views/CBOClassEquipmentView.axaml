<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="280"
             x:Class="Skua.Avalonia.Views.CBOClassEquipmentView"
             x:DataType="vm:CBOClassEquipmentViewModel">

    <StackPanel Margin="16" Spacing="8">
        <TextBlock Text="Farm equipment" FontWeight="Bold" />
        <TextBox Watermark="Helm" Text="{Binding SelectedFarmHelm}" />
        <TextBox Watermark="Armor" Text="{Binding SelectedFarmArmor}" />
        <TextBox Watermark="Cape" Text="{Binding SelectedFarmCape}" />
        <TextBox Watermark="Weapon" Text="{Binding SelectedFarmWeapon}" />
        <TextBox Watermark="Pet" Text="{Binding SelectedFarmPet}" />
        <TextBox Watermark="Ground item" Text="{Binding SelectedFarmGroundItem}" />
    </StackPanel>

</UserControl>
