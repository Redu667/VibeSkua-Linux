<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Skua.Avalonia.Views"
        mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="660"
        x:Class="Skua.Avalonia.Views.GameClientWindow"
        Title="VibeSkua — Client"
        Width="980" Height="660"
        MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <!-- A single bot client: the AQW game surface on its own live Ruffle player,
         so each launched window is an independent army member. -->
    <views:GameView x:Name="Game" />

</Window>
