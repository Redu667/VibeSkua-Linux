<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="380"
             x:Class="Skua.Avalonia.Views.PluginsView"
             x:DataType="vm:PluginsViewModel">

    <DockPanel Margin="24" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <TextBlock Text="Plugins" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Content="Load plugin" Command="{Binding LoadPluginCommand}" />
            <Button Content="Unload all" Command="{Binding UnloadAllPluginsCommand}" />
        </StackPanel>

        <ListBox ItemsSource="{Binding Plugins}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:PluginItemViewModel">
                    <StackPanel>
                        <TextBlock Text="{Binding Container.Plugin.Name}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Container.Plugin.Author}" Foreground="#A6ADC8" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>

</UserControl>
