<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="400"
             x:Class="Skua.Avalonia.Views.JunkItemsView"
             x:DataType="vm:JunkItemsViewModel">

    <DockPanel Margin="24" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <TextBlock Text="Junk Items" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Content="Refresh" Command="{Binding RefreshCommand}" />
            <Button Content="Sell all junk" Command="{Binding SellAllJunkCommand}" />
            <CheckBox Content="skip sell warning" IsChecked="{Binding SkipSellWarning}"
                      VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
            <Button Content="Mark junk" Command="{Binding MarkAsJunkCommand}" />
            <Button Content="Unmark" Command="{Binding UnmarkAsJunkCommand}" />
            <Button Content="Unmark all" Command="{Binding UnmarkAllJunkCommand}" />
        </StackPanel>

        <ListBox ItemsSource="{Binding Items}" />
    </DockPanel>

</UserControl>
