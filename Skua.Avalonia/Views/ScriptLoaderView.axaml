<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="360"
             x:Class="Skua.Avalonia.Views.ScriptLoaderView"
             x:DataType="vm:ScriptLoaderViewModel">

    <StackPanel Margin="24" Spacing="10">
        <TextBlock Text="Script Loader" FontSize="16" FontWeight="Bold" />
        <TextBlock Text="{Binding ScriptStatus}" FontWeight="SemiBold" />
        <TextBlock Text="{Binding LoadedScript}" Foreground="#A6ADC8" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Load" Command="{Binding LoadScriptCommand}" />
            <Button Content="Browse repo" Command="{Binding OpenScriptRepoCommand}" />
            <Button Content="Edit" Command="{Binding EditScriptCommand}" />
            <Button Content="VS Code" Command="{Binding OpenVSCodeCommand}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Start / Stop" Command="{Binding ToggleScriptCommand}"
                    IsEnabled="{Binding ToggleScriptEnabled}" />
            <Button Content="Pause" Command="{Binding TogglePauseScriptCommand}" />
            <Button Content="Config" Command="{Binding EditScriptConfigCommand}" />
        </StackPanel>
    </StackPanel>

</UserControl>
