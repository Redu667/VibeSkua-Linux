<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="380" d:DesignHeight="400"
             x:Class="Skua.Avalonia.Views.ThemeSettingsView"
             x:DataType="vm:ThemeSettingsViewModel">

    <StackPanel Margin="24" Spacing="12" HorizontalAlignment="Left" MinWidth="300">
        <TextBlock Text="Theme" FontSize="16" FontWeight="Bold" />

        <!-- Functional: flips Avalonia's RequestedThemeVariant. -->
        <ToggleSwitch Content="Dark theme" IsChecked="{Binding ThemeService.IsDarkTheme}" />

        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox Width="200" Watermark="theme name" Text="{Binding ThemeName}" />
            <Button Content="Save theme" Command="{Binding SaveThemeCommand}" Click="RefreshAfter_Click" />
        </StackPanel>

        <TextBlock Text="Presets and saved themes" FontWeight="Bold" Margin="0,8,0,0" />
        <ListBox x:Name="Themes" Height="140" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Apply" Click="Apply_Click" />
            <Button Content="Remove" Click="Remove_Click" />
        </StackPanel>
    </StackPanel>

</UserControl>
