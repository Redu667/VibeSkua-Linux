<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="480"
             x:Class="Skua.Avalonia.Views.AdvancedSkillEditorView"
             x:DataType="vm:AdvancedSkillEditorViewModel">

    <DockPanel Margin="24" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Spacing="10">
            <TextBlock Text="Advanced Skill Editor" FontSize="16" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Class" VerticalAlignment="Center" />
                <TextBox Width="180" Text="{Binding CurrentClassName}" />
                <TextBlock Text="Timeout (ms)" VerticalAlignment="Center" />
                <TextBox Width="80" Text="{Binding CurrentSkillTimeout}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="16">
                <CheckBox Content="Wait mode" IsChecked="{Binding UseWaitModeBool}" />
                <CheckBox Content="Reset combo on target change"
                          IsChecked="{Binding ResetComboOnTargetChange}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Move up" Command="{Binding MoveSkillUpCommand}" />
                <Button Content="Move down" Command="{Binding MoveSkillDownCommand}" />
                <Button Content="Remove" Command="{Binding RemoveSkillCommand}" />
                <Button Content="Save" Command="{Binding SaveSkillsCommand}" />
                <Button Content="Clear" Command="{Binding ClearSkillsCommand}" />
            </StackPanel>
        </StackPanel>

        <ListBox Margin="0,10,0,0"
                 ItemsSource="{Binding CurrentSkillsList}"
                 SelectedItem="{Binding SelectedSkill}"
                 SelectedIndex="{Binding SelectedSkillIndex}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:SkillItemViewModel">
                    <TextBlock Text="{Binding DisplayString}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>

</UserControl>
