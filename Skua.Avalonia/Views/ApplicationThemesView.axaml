<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="440"
             x:Class="Skua.Avalonia.Views.ApplicationThemesView"
             x:DataType="vm:ApplicationThemesViewModel">

    <!-- Composite: hosts the theme/scheme/background editors via the ViewLocator. -->
    <TabControl>
        <TabItem Header="Theme">
            <ContentControl Content="{Binding ThemeSettings}" />
        </TabItem>
        <TabItem Header="Colors">
            <ContentControl Content="{Binding ColorSchemeEditor}" />
        </TabItem>
        <TabItem Header="Background">
            <ContentControl Content="{Binding BackgroundTheme}" />
        </TabItem>
    </TabControl>

</UserControl>
