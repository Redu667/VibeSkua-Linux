<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="440"
             x:Class="Skua.Avalonia.Views.LoaderView"
             x:DataType="vm:LoaderViewModel">

    <DockPanel Margin="24" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Spacing="8">
            <TextBlock Text="Quest Loader" FontSize="16" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Width="160" Watermark="range e.g. 1-100" Text="{Binding QuestRange}" />
                <Button Content="Load range" Command="{Binding UpdateQuestsRangeCommand}" />
                <Button Content="Get quests" Command="{Binding GetQuestsCommand}" />
                <Button Content="Cancel" Command="{Binding CancelQuestLoadCommand}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsLoading}">
                <ProgressBar IsIndeterminate="True" Width="140" />
                <TextBlock Text="{Binding ProgressReport}" VerticalAlignment="Center" Foreground="#A6ADC8" />
            </StackPanel>
        </StackPanel>

        <ListBox Margin="0,10,0,0" ItemsSource="{Binding QuestIDs}"
                 SelectedIndex="{Binding SelectedIndex}" />
    </DockPanel>

</UserControl>
