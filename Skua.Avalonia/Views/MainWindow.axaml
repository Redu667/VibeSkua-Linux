<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Skua.Avalonia.ViewModels"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="Skua.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="VibeSkua — Linux"
        Width="900" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Padding="16,12" Background="#1E1E2E">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Image Source="avares://Skua.Avalonia/Assets/SkuaIcon.png"
                       Width="28" Height="28" VerticalAlignment="Center" />
                <TextBlock Text="VibeSkua" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" Foreground="#CBA6F7" />
                <TextBlock Text="native Linux build" FontSize="12"
                           VerticalAlignment="Center" Foreground="#A6ADC8" />
            </StackPanel>
        </Border>

        <!-- Navigation sidebar bound to the shell's Items. -->
        <ListBox DockPanel.Dock="Left" Width="180"
                 Background="#181825"
                 ItemsSource="{Binding Items}"
                 SelectedItem="{Binding Selected}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:NavItem">
                    <TextBlock Text="{Binding Title}" Padding="6,8" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ViewLocator turns Selected.Content (a Skua.Core ViewModel) into its View. -->
        <ContentControl Content="{Binding Selected.Content}" />
    </DockPanel>

</Window>
