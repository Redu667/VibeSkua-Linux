<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels.Manager;assembly=Skua.Core"
             xmlns:models="clr-namespace:Skua.Core.Models;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="Skua.Avalonia.Views.LauncherView"
             x:DataType="vm:LauncherViewModel">

    <DockPanel Margin="24" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <TextBlock Text="Clients" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Content="Launch Skua" Command="{Binding LaunchSkuaCommand}" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" Text="No clients running."
                   IsVisible="{Binding !SkuaProcesses.Count}"
                   Foreground="#A6ADC8" Margin="0,0,0,8" />

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding SkuaProcesses}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ProcessInfo">
                        <Border Padding="10" Margin="0,0,0,6" CornerRadius="6" Background="#181825">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding AccountName}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Stop"
                                        Command="{Binding $parent[ItemsControl].((vm:LauncherViewModel)DataContext).StopProcessCommand}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

</UserControl>
