<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
             mc:Ignorable="d" d:DesignWidth="460" d:DesignHeight="380"
             x:Class="Skua.Avalonia.Views.ToPickupDropsView"
             x:DataType="vm:ToPickupDropsViewModel">

    <DockPanel Margin="24" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Spacing="8">
            <TextBlock Text="Drops to pick up" FontSize="16" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Width="220" Watermark="item name(s)" Text="{Binding AddDropInput}" />
                <Button Content="Add" Command="{Binding AddDropCommand}" />
                <Button Content="Toggle" Command="{Binding ToggleDropsCommand}" />
            </StackPanel>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
            <Button Content="Remove all" Command="{Binding RemoveAllDropsCommand}" />
            <Button Content="Open notify drop" Command="{Binding OpenNotifyDropCommand}" />
        </StackPanel>

        <ListBox Margin="0,10,0,0" ItemsSource="{Binding ToPickup}" />
    </DockPanel>

</UserControl>
